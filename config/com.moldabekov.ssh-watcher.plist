<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.moldabekov.ssh-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/ssh-watcher</string>
    </array>

    <key>UserName</key>
    <string>root</string>

    <!-- Pin PATH to trusted system directories. ssh-watcher only spawns
         macOS-shipped binaries (/usr/bin/log, /usr/bin/osascript) and
         avoids PATH resolution for those, but we still scrub PATH in
         case future code or helper scripts rely on it. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- Avoid tight respawn loop if ssh-watcher fails on boot. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/var/log/ssh-watcher.out</string>

    <key>StandardErrorPath</key>
    <string>/var/log/ssh-watcher.err</string>

    <!-- Background QoS so ssh-watcher yields CPU/memory to interactive workloads. -->
    <key>ProcessType</key>
    <string>Background</string>

    <!-- Bound graceful-shutdown time so launchctl bootout doesn't hang. -->
    <key>ExitTimeOut</key>
    <integer>10</integer>
</dict>
</plist>
